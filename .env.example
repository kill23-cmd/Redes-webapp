# ============================================================
# .env.example — Copie para .env e preencha os valores reais
# NUNCA commite o arquivo .env no git
# ============================================================

# --- API Security ---
# Token para proteger o Backend (gerado automaticamente no primeiro boot se vazio)
API_TOKEN=

# --- PLAI API (Agente IA Autônomo da Cencosud) ---
# Substitui o OpenAI por segurança interna corporativa
PLAI_API_KEY=
PLAI_AGENT_ID=

# --- Zabbix ---
# URL da API do Zabbix (ex: https://zabbix.empresa.corp/api_jsonrpc.php)
ZABBIX_URL=https://zabbixbrasil.cencosud.corp/api_jsonrpc.php
# Usuário e senha do Zabbix — nunca deixar hardcoded no código
ZABBIX_USER=
ZABBIX_PASSWORD=

# --- SSH (defaults para conexões nos dispositivos de rede) ---
# Usuário e senha SSH padrão — nunca deixar hardcoded no código
SSH_USER=
SSH_PASSWORD=

# --- TACACS Keys (Cisco) ---
# Usado pelo template "Configurar TACACS" em config-templates.js
# Preencha com a chave correta antes de aplicar o template
TACACS_KEY_PRIMARIO=
TACACS_KEY_SECUNDARIO=

# --- TACACS Key (FortiSwitch) ---
TACACS_KEY_FORTI=
